{
  "name": "mntn-landing-page",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:all": "docker compose -f pocketbase/docker-compose.yml up -d && next dev",
    "dev:pb": "docker compose -f pocketbase/docker-compose.yml up",
    "dev:pb:stop": "docker compose -f pocketbase/docker-compose.yml down",
    "pb:restart": "docker compose -f pocketbase/docker-compose.yml restart pocketbase",
    "pb:superuser": "docker compose -f pocketbase/docker-compose.yml exec pocketbase /usr/local/bin/pocketbase --dir=/pb_data superuser upsert",
    "verify:site-views": "node pocketbase/scripts/verify-site-views.mjs",
    "import:site-stats": "node pocketbase/scripts/import-site-stats.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "gsap": "^3.12.5",
    "lenis": "^1.1.18",
    "next": "^15.3.3",
    "pocketbase": "^0.26.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "resend": "^4.5.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "typescript": "^5.8.3"
  }
}
