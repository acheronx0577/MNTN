# PocketBase (required)
# Local: http://127.0.0.1:8090
# Production: PocketBase host only — NO /api suffix
# e.g. https://k1y1g4i89co8bd1.ba7w.pocketbasecloud.com
NEXT_PUBLIC_POCKETBASE_URL=http://127.0.0.1:8090

# Resend (contact form — server only, set in Vercel → Settings → Environment Variables)
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=MNTN <onboarding@resend.dev>
CONTACT_TO_EMAIL=you@example.com

# Site metrics (server only — PocketBase admin for view counts)
POCKETBASE_ADMIN_EMAIL=admin@mntn.local
POCKETBASE_ADMIN_PASSWORD=your_admin_password

# Optional: GitHub link in the left site metrics panel
NEXT_PUBLIC_GITHUB_URL=https://github.com/acheronx0577/MNTN-Landing-Page-UI-main
